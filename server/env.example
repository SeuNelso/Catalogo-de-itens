# Configuração do Banco de Dados PostgreSQL
#
# --- Railway (recomendado se o Postgres está no Railway) ---
# 1) No painel: serviço PostgreSQL → aba Variables (ou Connect) → copie DATABASE_URL.
# 2) No serviço Node/API (deploy): em Variables, defina DATABASE_URL referenciando o Postgres
#    do mesmo projeto (menu "Variable Reference" / plugin PostgreSQL), ou cole o valor.
# 3) No PC (npm run dev): cole essa mesma DATABASE_URL em server/.env. Use a URL pública
#    do Postgres se o Railway mostrar "Public networking"; a URL interna só funciona entre
#    serviços dentro do Railway.
# O servidor ativa SSL automaticamente quando o host não é localhost.
#
# Use DATABASE_URL (única opção necessária no Railway) ou, para Postgres local, configure abaixo:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=catalogo
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DATABASE_URL=postgres://usuario:senha@localhost:5432/catalogo
#
# Migrações (npm run db:migrate:*) e a API usam esta mesma DATABASE_URL.
# Controlo de stock por utilizador: npm run db:migrate:usuarios-pode-controlo-stock
# Tickets / TRFL de movimentação interna (mesmo central): npm run db:migrate:movimentacao-interna
# Migrações DDL (npm run db:usuarios-roles): prefira a URL **direta** do Postgres (porta 5432).
# URLs do pooler/PgBouncer (ex. porta 6543) podem falhar ou não aplicar o constraint.
# Para aplicar migrações ao db:dev no Railway, DATABASE_URL tem de ser a URL pública desse Postgres.
# DATABASE_URL_RAILWAY NÃO substitui DATABASE_URL se esta estiver preenchida — só é fallback quando
# DATABASE_URL está vazio e DB_USER/DB_PASSWORD ainda são os placeholders do exemplo.

# Opcional: forçar SSL em desenvolvimento (o servidor já usa SSL para hosts que não são localhost)
# DATABASE_SSL=true

# Copiar dados do Railway para o banco local (npm run db:pull-railway), ou URL pública do Postgres.
# Se DATABASE_URL estiver vazio e DB_* ainda forem placeholders, a API usa esta variável (fallback).
DATABASE_URL_RAILWAY=

# Só estrutura (sem dados): npm run db:clone-schema — origem (ex.: produção). Se vazio, usa DATABASE_URL_RAILWAY.
# Destino é sempre DATABASE_URL (base vazia de teste). Requer pg_dump e psql (PATH ou caminhos abaixo no Windows).
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\16\bin\pg_dump.exe
# PSQL_PATH=C:\Program Files\PostgreSQL\16\bin\psql.exe
# DATABASE_URL_SCHEMA_SOURCE=

# Integridade do schema (npm run db:check). Timestamps catálogo: npm run db:migrate:catalog-timestamps

# Opcional: etiqueta gravada em schema_migrations ao correr npm run db:migrate:* (ex.: dev / producao).
# Ajuda a distinguir listagens se exportar queries entre ambientes. Ver: npm run db:migrations:history
# MIGRATION_ENV=dev

# Configuração do Servidor
PORT=3001
NODE_ENV=development

# CORS Origin permitido para chamadas cross-site.
# Se o frontend for servido no mesmo domínio, pode deixar como '*' (credenciais desativadas no servidor).
CORS_ORIGIN=*
# Logs de requests (recomendado ativar em produção com observabilidade centralizada)
REQUEST_LOG_ENABLED=false
# Rate limit de login (proteção de brute force)
RATE_LIMIT_LOGIN_WINDOW_MS=60000
RATE_LIMIT_LOGIN_MAX=20

# JWT Secret (GERE UMA CHAVE SEGURA!)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua-chave-secreta-aqui-altere-em-producao

# Cloudflare R2 (Armazenamento de Imagens)
# Obtenha essas credenciais no painel do Cloudflare R2
R2_BUCKET=seu-bucket-name
R2_ENDPOINT=https://seu-endpoint.r2.cloudflarestorage.com
R2_ACCESS_KEY=sua-access-key
R2_SECRET_KEY=sua-secret-key

# Integrações OAuth2 (M2M)
# Duração do access token em segundos (mínimo 300)
INTEGRATION_TOKEN_TTL_SECONDS=3600
# Limite de chamadas por cliente/minuto na API de integração
INTEGRATION_RATE_LIMIT_PER_MIN=300
