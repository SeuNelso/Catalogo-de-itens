{
  "name": "catalogo-itens",
  "version": "1.0.0",
  "description": "Catálogo de itens com reconhecimento por imagem",
  "main": "server/index.js",
  "scripts": {
    "db:init": "node server/run-init-db.js",
    "db:armazens": "node server/run-armazens-requisicoes.js",
    "db:armazens-tipo": "node server/run-armazens-tipo.js",
    "db:usuarios-roles": "node server/run-usuarios-roles.js",
    "db:pull-railway": "node server/pull-railway-db.js",
    "db:migrate": "node server/run-migration.js",
    "db:migrate:lote": "node server/run-migration.js lote",
    "db:migrate:serial": "node server/run-migration.js serial",
    "db:migrate:bobinas": "node server/run-migration.js bobinas",
    "db:migrate:status-finalizado": "node server/run-migration.js status-finalizado",
    "db:migrate:tra-gerada": "node server/run-migration.js tra-gerada",
    "db:migrate:separacao": "node server/run-migration.js separacao-confirmada",
    "db:migrate:status-fases": "node server/run-migration.js status-fases",
    "db:migrate:preparacao-confirmada": "node server/run-migration.js preparacao-confirmada",
    "db:migrate:armazens-tipo": "node server/run-migration.js armazens-tipo",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "start": "node server/index.js",
    "heroku-postbuild": "cd client && rm -rf node_modules package-lock.json && npm install && npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.858.0",
    "@aws-sdk/client-s3": "^3.858.0",
    "@google-cloud/vision": "^5.3.0",
    "aws-sdk": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "canvas": "^3.1.2",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "form-data": "^4.0.3",
    "googleapis": "^152.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.3",
    "sharp": "^0.34.3",
    "sqlite3": "^5.0.2",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "catalogo",
    "reconhecimento",
    "imagem",
    "itens"
  ],
  "author": "Seu Nome",
  "license": "MIT"
}
